# Database
DATABASE_URL=postgresql+asyncpg://testboost:testboost@localhost:5433/testboost

# API
API_KEY=your-api-key-here
API_HOST=0.0.0.0
API_PORT=8000

# LLM Provider — one of: openai, anthropic, google-genai
LLM_PROVIDER=openai

# Model path or name (as loaded by the LLM backend)
MODEL=/path/to/your/local/model/

# --- Provider-specific settings ---

# For local vLLM / OpenAI-compatible endpoint:
OPENAI_API_BASE=https://your-internal-llm-endpoint/v1
OPENAI_API_KEY=dummy

# For cloud providers (uncomment as needed):
# GOOGLE_API_KEY=your-google-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key

# Startup timeout for LLM connection (seconds)
STARTUP_TIMEOUT=30

# --- Corporate network / proxy / SSL ---
# NO_PROXY=*.example.corp,10.0.0.*,127.0.0.1,localhost
# SSL_CERT_FILE=/path/to/corp-ca-bundle.pem
# REQUESTS_CA_BUNDLE=/path/to/corp-ca-bundle.pem

# LangSmith Observability
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=testboost
LANGSMITH_TRACING=true

# Application
LOG_LEVEL=INFO
DEBUG=false

# Session Management
SESSION_RETENTION_DAYS=365
PROJECT_LOCK_TIMEOUT_SECONDS=3600

# Docker
DOCKER_HOST=unix:///var/run/docker.sock
MAVEN_CACHE_PATH=/tmp/maven-cache
